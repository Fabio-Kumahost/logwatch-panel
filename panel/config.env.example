# Copy to /etc/logwatch-panel/config.env (the installer does this for you).
NODE_ENV=production
HOST=127.0.0.1
PORT=8088
# Public URL agents use to reach the panel (used to build install one-liners).
PUBLIC_URL=https://panel.example.com
# Generate with: openssl rand -hex 48
JWT_SECRET=change-me-to-a-long-random-string
DB_PATH=./data/logwatch.db
AGENT_BIN_DIR=../agent-bin
# Log retention in days (0 = keep forever)
RETENTION_DAYS=14
# Mark a server offline after this many seconds without logs/heartbeat
AGENT_OFFLINE_SECONDS=120
# Behind a reverse proxy? Trust X-Forwarded-* headers.
TRUST_PROXY=true
# Login brute-force protection
LOGIN_MAX_ATTEMPTS=8
LOGIN_WINDOW_MINUTES=5
# Optional: protect GET /metrics (Prometheus) with a bearer token (unset = open)
METRICS_TOKEN=
# Optional AI assistant (Claude). Set your Anthropic API key to enable
# "Explain with AI" and natural-language search. Unset = feature disabled.
ANTHROPIC_API_KEY=
# Model for the AI assistant (default: claude-opus-4-8)
AI_MODEL=claude-opus-4-8
# Optional UDP syslog listener port (0 = disabled, e.g. 5514)
SYSLOG_UDP_PORT=0

# --- Optional SSO via OpenID Connect (Authentik, Keycloak, Google, Azure AD…) ---
# All three must be set to enable SSO. Redirect URI defaults to
# <PUBLIC_URL>/api/v1/auth/oidc/callback — register exactly that at the provider.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://panel.example.com/api/v1/auth/oidc/callback
OIDC_SCOPE=openid email profile
# Role for first-time SSO users: admin | operator | viewer (default viewer)
OIDC_DEFAULT_ROLE=viewer
# Optional comma-separated email-domain allowlist (e.g. example.com,corp.io)
OIDC_ALLOWED_DOMAINS=
OIDC_BUTTON_LABEL=Sign in with SSO
